{
  "expo": {
    "name": "My Public Samachara",
    "slug": "public-samachar-mobile",
    "version": "1.18.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "publicsamachar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/images/splash-image.png",
      "imageWidth": 300,
      "resizeMode": "contain",
      "backgroundColor": "#1AAA94"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.publicsamachar.app",
      "buildNumber": "1",
      "jsEngine": "hermes",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Select photos and videos to report news.",
        "NSCameraUsageDescription": "Capture photos for news submission.",
        "NSMicrophoneUsageDescription": "Record audio for news videos.",
        "NSLocationWhenInUseUsageDescription": "Auto-fill your location for news reporting."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1AAA94"
      },
      "package": "com.publicsamachar.app",
      "versionCode": 17,
      "jsEngine": "hermes",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Access photos to submit news with images.",
          "cameraPermission": "Take photos for news submission."
        }
      ],
      "expo-video",
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Auto-fill your location for news reporting."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4bbeff94-dd72-465a-8ab1-ea1a945bfdff"
      }
    }
  }
}
